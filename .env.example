# Knox configuration — copy this file to ".env" and fill in your values.
# .env is gitignored, so secrets (like the router password) stay local.
# Any KNOX_* setting can go here instead of the shell environment.

# --- Router integration (per-device bandwidth polling) ---
KNOX_ROUTER_URL=http://192.168.110.1
KNOX_ROUTER_USER=admin
KNOX_ROUTER_PASSWORD=

# --- Dashboard ---
# KNOX_PASSWORD=            # require login (blank = no auth)
# KNOX_WEB_HOST=127.0.0.1   # 0.0.0.0 to reach from other devices

# --- Features (1 = on) ---
# KNOX_CAPTURE=0            # capture traffic/bandwidth (needs admin)

# --- DNS-logging resolver (Pi-hole-lite: per-device domain history) ---
# Turn ON to log every domain each device looks up -- see WHERE devices talk,
# not just how much. Recommended on the always-on Pi, not the Windows PC.
# One-time on the Pi:  bash scripts/enable-dns-logging.sh   (frees port 53)
# Then point your router's DHCP DNS at this host's IP, and set a secondary
# DNS (e.g. 1.1.1.1) on the router as a fallback for when Knox is down.
# KNOX_DNS_SERVER=0         # 1 = run the forwarding/logging resolver (needs :53 / root)
# KNOX_DNS_PORT=53          # use e.g. 15353 to test without admin
# KNOX_DNS_UPSTREAM=1.1.1.1 # where Knox forwards the real lookups

# --- Discovery ---
# KNOX_SUBNETS=192.168.110.0/24

# --- Push notifications ---
# KNOX_NTFY_TOPIC=          # ntfy topic for phone push on new devices
